---
exclude_paths:
  - .tox/
  - .venv/
  - .github/

parseable: true

quiet: false

skip_list:
  - '301'  # Commands should not change things if nothing needs doing'
  - '305'  # Use shell only when shell functionality is required
  - '502'  # All tasks should be named
  - '505'  # referenced files must exist

use_default_rules: true

verbosity: 0
